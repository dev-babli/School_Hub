# EditorConfig: prevent BOM and encoding issues that cause
# "Invalid or unexpected token" in Next.js layout.js
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,ts,tsx,json,css,scss,html}]
charset = utf-8
